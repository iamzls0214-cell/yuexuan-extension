{
  "name": "yuexuan-extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:chrome && npm run build:compat",
    "build:chrome": "vite build && node scripts/build-entries.mjs chrome && node scripts/postbuild.cjs chrome",
    "build:compat": "vite build --mode compat && node scripts/build-entries.mjs compat && node scripts/postbuild.cjs compat",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:customs-data": "node scripts/build-customs-data.mjs",
    "preview": "vite preview",
    "server": "python3 server/server.py",
    "server:node": "node server/index.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/webextension-polyfill": "^0.12.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "vite-plugin-web-extension": "^4.5.1",
    "webextension-polyfill": "^0.12.0",
    "express": "^5.1.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
