{
  "manifest_version": 2,
  "name": "越海选品",
  "version": "1.0.0",
  "description": "三源数据交叉分析，发现东南亚蓝海品类 — 中国海关数据 + 1688出厂价 + Shopee多国行情",
  "minimum_chrome_version": "86",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "browser_action": {
    "default_title": "越海选品",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["https://*.1688.com/*"],
      "js": ["content/1688.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.shopee.vn/*",
        "https://*.shopee.co.th/*",
        "https://*.shopee.co.id/*",
        "https://*.shopee.ph/*"
      ],
      "js": ["content/shopee.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "tabs",
    "https://*.1688.com/*",
    "https://*.shopee.vn/*",
    "https://*.shopee.co.th/*",
    "https://*.shopee.co.id/*",
    "https://*.shopee.ph/*",
    "https://api.customsdata.net/*"
  ],
  "web_accessible_resources": [
    "assets/*"
  ]
}
